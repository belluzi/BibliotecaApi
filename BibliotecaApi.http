@hostname = http://localhost:5023
@token = COLE_O_TOKEN_RETORNADO_AQUI

### TASK 8: AUTHENTICATION (Gerar Token - Executar Primeiro)
POST {{hostname}}/Auth/generate-token
Content-Type: application/json

{ "email": "admin@teste.com", "senha": "bibliotecaapiteste" }

### TASK 1: VALIDAR CPF (Feature)
# Teste: Tentar cadastrar CPF que já existe no banco
POST {{hostname}}/Usuario/Cadastrar
Authorization: Bearer {{token}}
Content-Type: application/json

{ "nome": "Repetido", "cpf": "12345678901", "email": "repetido@teste.com" }

### TASK 2: VALIDAR ISBN (Feature)
# Tentar cadastrar livro com ISBN inválido (deve falhar)
POST {{hostname}}/Livro/Cadastrar
Authorization: Bearer {{token}}
Content-Type: application/json

{ "titulo": "Teste ISBN", "autor": "Autor Teste", "isbn": "12345" }

### TASK 3: BUG MULTA NO PRAZO (Bugfix)
# Devolver um livro no prazo (deve retornar multa R$ 0,00)
POST {{hostname}}/Emprestimo/Devolver
Authorization: Bearer {{token}}
Content-Type: application/json

{ "idEmprestimo": 1, "dataDevolucao": "2026-03-23" }

### TASK 4: LIVRO JÁ EMPRESTADO (Bugfix)
# Tentar emprestar um livro que já está emprestado
POST {{hostname}}/Emprestimo/Cadastrar
Authorization: Bearer {{token}}
Content-Type: application/json

{ "idUsuario": 1, "idLivro": 1, "dataPrevistaDevolucao": "2026-04-23" }

### TASK 5: LISTAR LIVROS (Feature)
# Rota pública
GET {{hostname}}/Livro/Listar

### TASK 6: USUÁRIO COM ATRASO (Feature)
# Tentar novo empréstimo com usuário que tem atraso
POST {{hostname}}/Emprestimo/Cadastrar
Authorization: Bearer {{token}}
Content-Type: application/json

{ "idUsuario": 2, "idLivro": 2, "dataPrevistaDevolucao": "2026-03-28" }

### TASK 7: REGRA DE MULTA ESCALONADA (Feature)
# Devolver com atraso para testar cálculo escalonado
POST {{hostname}}/Emprestimo/Devolver
Authorization: Bearer {{token}}
Content-Type: application/json

{ "idEmprestimo": 2, "dataDevolucao": "2026-04-02" }